 "font_size": 14,
 "html": "<div class=\"slip-wrap\">\n\n  {% if letter_head and not no_letterhead %}\n  <div class=\"letter-head\">{{ letter_head }}</div>\n  {% endif %}\n\n  <!-- \u2550\u2550\u2550 HEADER BAND \u2550\u2550\u2550 -->\n  <div class=\"slip-header\">\n    <div class=\"slip-header-left\">\n      <div class=\"slip-label\">SALARY SLIP</div>\n      <div class=\"slip-period\">\n        {{ frappe.utils.formatdate(doc.start_date, \"MMMM d, YYYY\") }} &ndash;\n        {{ frappe.utils.formatdate(doc.end_date, \"MMMM d, YYYY\") }}\n      </div>\n    </div>\n    <div class=\"slip-header-right\">\n      <div class=\"slip-company\">{{ doc.company }}</div>\n      <div class=\"slip-posted\">Issued: {{ frappe.utils.formatdate(doc.posting_date, \"d MMM YYYY\") }}</div>\n    </div>\n  </div>\n\n  <!-- \u2550\u2550\u2550 EMPLOYEE INFO GRID \u2550\u2550\u2550 -->\n  <div class=\"info-grid\">\n    <div class=\"info-item\">\n      <span class=\"info-label\">Employee</span>\n      <span class=\"info-value\">{{ doc.employee_name }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Employee ID</span>\n      <span class=\"info-value\">{{ doc.employee }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Department</span>\n      <span class=\"info-value\">{{ doc.department or \"\u2014\" }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Designation</span>\n      <span class=\"info-value\">{{ doc.designation or \"\u2014\" }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Branch</span>\n      <span class=\"info-value\">{{ doc.branch or \"\u2014\" }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Payroll Frequency</span>\n      <span class=\"info-value\">{{ doc.payroll_frequency or \"\u2014\" }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Mode of Payment</span>\n      <span class=\"info-value\">{{ doc.mode_of_payment or \"\u2014\" }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Currency</span>\n      <span class=\"info-value\">{{ doc.currency }}</span>\n    </div>\n    {% if doc.bank_name %}\n    <div class=\"info-item\">\n      <span class=\"info-label\">Bank</span>\n      <span class=\"info-value\">{{ doc.bank_name }}</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">Account No.</span>\n      <span class=\"info-value\">{{ doc.bank_account_no or \"\u2014\" }}</span>\n    </div>\n    {% endif %}\n  </div>\n\n  <!-- \u2550\u2550\u2550 ATTENDANCE \u2550\u2550\u2550 -->\n  <div class=\"section-title\">Attendance &amp; Payment Days</div>\n  <table class=\"data-table attendance-table\">\n    <thead>\n      <tr>\n        <th>Working Days</th>\n        <th>Payment Days</th>\n        <th>Absent Days</th>\n        <th>Leave Without Pay</th>\n        <th>Unmarked Days</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td class=\"num\">{{ doc.total_working_days }}</td>\n        <td class=\"num\">{{ doc.payment_days }}</td>\n        <td class=\"num\">{{ doc.absent_days or 0 }}</td>\n        <td class=\"num\">{{ doc.leave_without_pay or 0 }}</td>\n        <td class=\"num\">{{ doc.unmarked_days or 0 }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <!-- \u2550\u2550\u2550 EARNINGS + GROSS DEDUCTIONS \u2550\u2550\u2550 -->\n  <div class=\"two-col-tables\">\n\n    <div class=\"col-table\">\n      <div class=\"section-title\">Earnings</div>\n      <table class=\"data-table\">\n        <thead>\n          <tr>\n            <th>Component</th>\n            <th class=\"num\">Amount ({{ doc.currency }})</th>\n          </tr>\n        </thead>\n        <tbody>\n          {% for row in doc.earnings %}\n          <tr>\n            <td>{{ row.salary_component }}</td>\n            <td class=\"num\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n          </tr>\n          {% else %}\n          <tr><td colspan=\"2\" class=\"empty\">No earnings recorded</td></tr>\n          {% endfor %}\n        </tbody>\n        <tfoot>\n          <tr class=\"subtotal-row\">\n            <td><strong>Gross Pay</strong></td>\n            <td class=\"num\"><strong>{{ frappe.utils.fmt_money(doc.gross_pay, currency=doc.currency) }}</strong></td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n    <div class=\"col-table\">\n      <div class=\"section-title\">Gross Deductions</div>\n      <table class=\"data-table\">\n        <thead>\n          <tr>\n            <th>Component</th>\n            <th class=\"num\">Amount ({{ doc.currency }})</th>\n          </tr>\n        </thead>\n        <tbody>\n          {% for row in doc.gross_deductions %}\n          <tr>\n            <td>{{ row.salary_component }}</td>\n            <td class=\"num\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n          </tr>\n          {% else %}\n          <tr><td colspan=\"2\" class=\"empty\">No gross deductions recorded</td></tr>\n          {% endfor %}\n        </tbody>\n        <tfoot>\n          <tr class=\"subtotal-row\">\n            <td><strong>Total</strong></td>\n            <td class=\"num\">\n              <strong>\n                {{ frappe.utils.fmt_money(\n                    doc.gross_deductions | sum(attribute='amount'),\n                    currency=doc.currency\n                ) }}\n              </strong>\n            </td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n  </div>\n\n  <!-- \u2550\u2550\u2550 DEDUCTIONS + RELIEFS \u2550\u2550\u2550 -->\n  <div class=\"two-col-tables\">\n\n    <div class=\"col-table\">\n      <div class=\"section-title\">Deductions</div>\n      <table class=\"data-table\">\n        <thead>\n          <tr>\n            <th>Component</th>\n            <th class=\"num\">Amount ({{ doc.currency }})</th>\n          </tr>\n        </thead>\n        <tbody>\n          {% for row in doc.deductions %}\n          <tr>\n            <td>{{ row.salary_component }}</td>\n            <td class=\"num\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n          </tr>\n          {% else %}\n          <tr><td colspan=\"2\" class=\"empty\">No deductions recorded</td></tr>\n          {% endfor %}\n        </tbody>\n        <tfoot>\n          <tr class=\"subtotal-row\">\n            <td><strong>Total Deductions</strong></td>\n            <td class=\"num\"><strong>{{ frappe.utils.fmt_money(doc.total_deduction, currency=doc.currency) }}</strong></td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n    <div class=\"col-table\">\n      <div class=\"section-title\">Reliefs</div>\n      <table class=\"data-table\">\n        <thead>\n          <tr>\n            <th>Component</th>\n            <th class=\"num\">Amount ({{ doc.currency }})</th>\n          </tr>\n        </thead>\n        <tbody>\n          {% for row in doc.reliefs %}\n          <tr>\n            <td>{{ row.salary_component }}</td>\n            <td class=\"num\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n          </tr>\n          {% else %}\n          <tr><td colspan=\"2\" class=\"empty\">No reliefs recorded</td></tr>\n          {% endfor %}\n        </tbody>\n        <tfoot>\n          <tr class=\"subtotal-row\">\n            <td><strong>Total Relief</strong></td>\n            <td class=\"num\"><strong>{{ frappe.utils.fmt_money(doc.total_relief or 0, currency=doc.currency) }}</strong></td>\n          </tr>\n        </tfoot>\n      </table>\n    </div>\n\n  </div>\n\n  <!-- \u2550\u2550\u2550 NET PAY SUMMARY \u2550\u2550\u2550 -->\n  <div class=\"net-summary\">\n    <table class=\"summary-table\">\n      <tbody>\n        <tr>\n          <td class=\"s-label\">Gross Pay</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.gross_pay, currency=doc.currency) }}</td>\n          <td class=\"s-label\">Total Deductions</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.total_deduction, currency=doc.currency) }}</td>\n        </tr>\n        <tr>\n          <td class=\"s-label\">Taxable Income</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.taxable_income or 0, currency=doc.currency) }}</td>\n          <td class=\"s-label\">Total Relief</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.total_relief or 0, currency=doc.currency) }}</td>\n        </tr>\n        {% if doc.year_to_date %}\n        <tr>\n          <td class=\"s-label\">Year-to-Date</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.year_to_date, currency=doc.currency) }}</td>\n          <td class=\"s-label\">Month-to-Date</td>\n          <td class=\"s-value\">{{ frappe.utils.fmt_money(doc.month_to_date or 0, currency=doc.currency) }}</td>\n        </tr>\n        {% endif %}\n      </tbody>\n    </table>\n\n    <div class=\"net-pay-band\">\n      <span class=\"net-pay-label\">NET PAY</span>\n      <span class=\"net-pay-amount\">{{ frappe.utils.fmt_money(doc.rounded_total, currency=doc.currency) }}</span>\n    </div>\n\n    <div class=\"in-words\">\n      <strong>In Words:</strong> {{ doc.total_in_words }}\n    </div>\n  </div>\n\n  <!-- \u2550\u2550\u2550 FOOTER \u2550\u2550\u2550 -->\n  <div class=\"slip-footer\">\n    <div class=\"footer-note\">This is a system-generated salary slip and does not require a signature.</div>\n    <div class=\"footer-brand\">Powered by BWK-HEALTH</div>\n  </div>\n\n</div>\n\n\n<style>\n\n.slip-wrap {\n  font-family: \"Palatino Linotype\", Palatino, \"Book Antiqua\", Georgia, serif;\n  font-size: 10pt;\n  color: #1a1a1a;\n  max-width: 800px;\n  margin: 0 auto;\n}\n\n/* HEADER */\n.slip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-end;\n  background: #1b3a5c;\n  color: #fff;\n  padding: 16px 20px 14px;\n}\n\n.slip-label {\n  font-size: 18pt;\n  font-weight: bold;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n}\n\n.slip-period {\n  font-size: 9pt;\n  margin-top: 4px;\n  opacity: 0.85;\n}\n\n.slip-header-right { text-align: right; }\n\n.slip-company {\n  font-size: 12pt;\n  font-weight: bold;\n  letter-spacing: 0.04em;\n}\n\n.slip-posted {\n  font-size: 8.5pt;\n  margin-top: 4px;\n  opacity: 0.8;\n}\n\n/* EMPLOYEE INFO GRID */\n.info-grid {\n  display: flex;\n  flex-wrap: wrap;\n  border: 1px solid #1b3a5c;\n  border-top: none;\n  margin-bottom: 18px;\n}\n\n.info-item {\n  display: flex;\n  flex-direction: column;\n  width: 25%;\n  border-right: 1px solid #d0d8e4;\n  border-bottom: 1px solid #d0d8e4;\n  padding: 7px 12px;\n  box-sizing: border-box;\n}\n\n.info-item:nth-child(4n) { border-right: none; }\n\n.info-label {\n  font-size: 7.5pt;\n  text-transform: uppercase;\n  letter-spacing: 0.07em;\n  color: #5a7a9a;\n  margin-bottom: 2px;\n}\n\n.info-value {\n  font-size: 10pt;\n  font-weight: 600;\n}\n\n/* SECTION TITLES */\n.section-title {\n  font-size: 8.5pt;\n  font-weight: bold;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  color: #fff;\n  background: #2c5f8a;\n  padding: 5px 10px;\n  margin-top: 14px;\n  margin-bottom: 0;\n}\n\n/* DATA TABLES */\n.data-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 9.5pt;\n}\n\n.data-table thead tr { background: #eef3f8; }\n\n.data-table th {\n  padding: 6px 10px;\n  text-align: left;\n  font-size: 8pt;\n  font-weight: bold;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: #2c5f8a;\n  border-bottom: 2px solid #2c5f8a;\n  border-right: 1px solid #d0d8e4;\n}\n\n.data-table th:last-child { border-right: none; }\n\n.data-table td {\n  padding: 5px 10px;\n  border-bottom: 1px solid #e8edf3;\n  border-right: 1px solid #e8edf3;\n}\n\n.data-table td:last-child { border-right: none; }\n.data-table tbody tr:nth-child(even) { background: #f7f9fc; }\n\n.data-table tfoot .subtotal-row td {\n  background: #dce8f3;\n  border-top: 2px solid #2c5f8a;\n  padding: 6px 10px;\n}\n\n.data-table .num { text-align: right; }\n\n.data-table .empty {\n  text-align: center;\n  color: #999;\n  font-style: italic;\n  padding: 10px;\n}\n\n/* ATTENDANCE */\n.attendance-table thead th,\n.attendance-table td { text-align: center; }\n\n/* SIDE-BY-SIDE */\n.two-col-tables {\n  display: flex;\n  gap: 0;\n  margin-bottom: 4px;\n}\n\n.col-table { flex: 1; }\n.col-table:first-child { margin-right: 14px; }\n\n/* NET SUMMARY */\n.net-summary {\n  margin-top: 18px;\n  border: 1px solid #1b3a5c;\n}\n\n.summary-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 9.5pt;\n}\n\n.summary-table td {\n  padding: 6px 14px;\n  border-bottom: 1px solid #d0d8e4;\n  border-right: 1px solid #d0d8e4;\n}\n\n.summary-table td:last-child { border-right: none; }\n\n.s-label {\n  font-size: 8pt;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: #5a7a9a;\n  width: 22%;\n}\n\n.s-value {\n  font-weight: 600;\n  text-align: right;\n  width: 28%;\n}\n\n.net-pay-band {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  background: #1b3a5c;\n  color: #fff;\n  padding: 12px 18px;\n}\n\n.net-pay-label {\n  font-size: 13pt;\n  letter-spacing: 0.15em;\n  font-weight: bold;\n  text-transform: uppercase;\n}\n\n.net-pay-amount {\n  font-size: 16pt;\n  font-weight: bold;\n}\n\n.in-words {\n  padding: 8px 14px;\n  font-size: 9pt;\n  font-style: italic;\n  background: #f2f6fa;\n  border-top: 1px solid #d0d8e4;\n}\n\n/* FOOTER */\n.slip-footer {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-top: 22px;\n  padding-top: 8px;\n  border-top: 1px solid #1b3a5c;\n  font-size: 8pt;\n  color: #666;\n}\n\n.footer-brand {\n  font-weight: bold;\n  color: #2c5f8a;\n  letter-spacing: 0.05em;\n}\n\n@media print {\n  .slip-wrap { max-width: 100%; }\n  .two-col-tables { page-break-inside: avoid; }\n  .net-summary { page-break-inside: avoid; }\n}\n\n</style>",
