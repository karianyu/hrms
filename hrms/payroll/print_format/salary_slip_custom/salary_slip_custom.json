 "doctype": "Print Format",
 "font_size": 14,
 "html": "<div class=\"print-format\">\n\n{% if letter_head and not no_letterhead %}\n<div class=\"letter-head\">{{ letter_head }}</div>\n<hr>\n{% endif %}\n\n<hr>\n\n<p class=\"date\">\n{{ frappe.utils.formatdate(doc.posting_date, \"MMMM d, YYYY\") }}\n</p>\n\n<h2 class=\"report-title\">\n{{ doc.employee_name | title }} | Salary Slip\n</h2>\n\n<p>\nDear {{ (doc.employee_name or \"\").split(\" \") | first }},\n</p>\n\n<p>\nPlease find below your salary details for the period\n{{ frappe.utils.formatdate(doc.start_date, \"MMMM d, YYYY\") }}\nto\n{{ frappe.utils.formatdate(doc.end_date, \"MMMM d, YYYY\") }}.\n</p>\n\n\n<!-- EMPLOYEE INFO -->\n\n<h3 class=\"section-title\">Employee Details</h3>\n\n<table class=\"info-table\">\n  <tbody>\n    <tr>\n      <td class=\"label-cell\">Employee ID</td>\n      <td>{{ doc.employee }}</td>\n      <td class=\"label-cell\">Department</td>\n      <td>{{ doc.department or \"\u2014\" }}</td>\n    </tr>\n    <tr>\n      <td class=\"label-cell\">Designation</td>\n      <td>{{ doc.designation or \"\u2014\" }}</td>\n      <td class=\"label-cell\">Branch</td>\n      <td>{{ doc.branch or \"\u2014\" }}</td>\n    </tr>\n    <tr>\n      <td class=\"label-cell\">Payroll Frequency</td>\n      <td>{{ doc.payroll_frequency or \"\u2014\" }}</td>\n      <td class=\"label-cell\">Mode of Payment</td>\n      <td>{{ doc.mode_of_payment or \"\u2014\" }}</td>\n    </tr>\n    {% if doc.bank_name %}\n    <tr>\n      <td class=\"label-cell\">Bank</td>\n      <td>{{ doc.bank_name }}</td>\n      <td class=\"label-cell\">Account No.</td>\n      <td>{{ doc.bank_account_no or \"\u2014\" }}</td>\n    </tr>\n    {% endif %}\n  </tbody>\n</table>\n\n\n<!-- PAYMENT DAYS -->\n\n<h3 class=\"section-title\">Attendance Summary</h3>\n\n<table class=\"result-table\">\n  <thead>\n    <tr>\n      <th>Working Days</th>\n      <th>Payment Days</th>\n      <th>Absent Days</th>\n      <th>Leave Without Pay</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td>{{ doc.total_working_days }}</td>\n      <td>{{ doc.payment_days }}</td>\n      <td>{{ doc.absent_days or 0 }}</td>\n      <td>{{ doc.leave_without_pay or 0 }}</td>\n    </tr>\n  </tbody>\n</table>\n\n\n<!-- EARNINGS -->\n\n{% if doc.earnings %}\n<h3 class=\"section-title\">Earnings</h3>\n\n<table class=\"result-table\">\n  <thead>\n    <tr>\n      <th>Component</th>\n      <th style=\"text-align:right;\">Amount ({{ doc.currency }})</th>\n    </tr>\n  </thead>\n  <tbody>\n    {% for row in doc.earnings %}\n    <tr>\n      <td>{{ row.salary_component }}</td>\n      <td style=\"text-align:right;\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n    </tr>\n    {% endfor %}\n    <tr class=\"totals-row\">\n      <td><strong>Gross Pay</strong></td>\n      <td style=\"text-align:right;\"><strong>{{ frappe.utils.fmt_money(doc.gross_pay, currency=doc.currency) }}</strong></td>\n    </tr>\n  </tbody>\n</table>\n{% endif %}\n\n\n<!-- DEDUCTIONS -->\n\n{% if doc.deductions %}\n<h3 class=\"section-title\">Deductions</h3>\n\n<table class=\"result-table\">\n  <thead>\n    <tr>\n      <th>Component</th>\n      <th style=\"text-align:right;\">Amount ({{ doc.currency }})</th>\n    </tr>\n  </thead>\n  <tbody>\n    {% for row in doc.deductions %}\n    <tr>\n      <td>{{ row.salary_component }}</td>\n      <td style=\"text-align:right;\">{{ frappe.utils.fmt_money(row.amount, currency=doc.currency) }}</td>\n    </tr>\n    {% endfor %}\n    <tr class=\"totals-row\">\n      <td><strong>Total Deductions</strong></td>\n      <td style=\"text-align:right;\"><strong>{{ frappe.utils.fmt_money(doc.total_deduction, currency=doc.currency) }}</strong></td>\n    </tr>\n  </tbody>\n</table>\n{% endif %}\n\n\n<!-- NET PAY SUMMARY -->\n\n<h3 class=\"section-title\">Net Pay Summary</h3>\n\n<table class=\"result-table summary-table\">\n  <tbody>\n    <tr>\n      <td class=\"label-cell\">Gross Pay</td>\n      <td style=\"text-align:right;\">{{ frappe.utils.fmt_money(doc.gross_pay, currency=doc.currency) }}</td>\n    </tr>\n    <tr>\n      <td class=\"label-cell\">Total Deductions</td>\n      <td style=\"text-align:right;\">{{ frappe.utils.fmt_money(doc.total_deduction, currency=doc.currency) }}</td>\n    </tr>\n    <tr class=\"net-pay-row\">\n      <td><strong>Net Pay</strong></td>\n      <td style=\"text-align:right;\"><strong>{{ frappe.utils.fmt_money(doc.rounded_total, currency=doc.currency) }}</strong></td>\n    </tr>\n  </tbody>\n</table>\n\n<p class=\"in-words\">\n  <strong>Amount in Words:</strong> {{ doc.total_in_words }}\n</p>\n\n{% if doc.year_to_date %}\n<p class=\"ytd-note\">\n  <strong>Year-to-Date Net Pay:</strong> {{ frappe.utils.fmt_money(doc.year_to_date, currency=doc.currency) }}\n</p>\n{% endif %}\n\n\n<div class=\"text-right\">\n  {%- if doc.company -%}\n  <h6 class=\"text-titlecase\"><b>Issued By: </b></h6>\n  <h6 class=\"text-uppercase\"><b>{{ doc.company }}</b></h6>\n  {%- endif -%}\n</div>\n\n\n<div class=\"footer\">\nPowered By BWK-HEALTH\n</div>\n\n</div>\n\n\n\n<style>\n\n.print-format {\n  font-family: Georgia, \"Times New Roman\", Times, serif;\n  font-size: 11pt;\n  color: #000;\n}\n\n.date {\n  margin-top: 10px;\n}\n\n.report-title {\n  margin-top: 5px;\n  margin-bottom: 20px;\n  font-size: 16pt;\n}\n\n.section-title {\n  margin-top: 35px;\n  margin-bottom: 10px;\n  font-size: 13pt;\n  border-bottom: 2px solid #000;\n  padding-bottom: 4px;\n}\n\n/* Two-column info table */\n.info-table {\n  width: 100%;\n  border-collapse: collapse;\n  margin-top: 5px;\n  margin-bottom: 10px;\n}\n\n.info-table td {\n  padding: 5px 8px;\n  border: 1px solid #ccc;\n  font-size: 10.5pt;\n}\n\n.info-table .label-cell {\n  font-weight: bold;\n  background-color: #f5f5f5;\n  width: 18%;\n}\n\n/* Main result tables */\n.result-table {\n  width: 100%;\n  border-collapse: collapse;\n  margin-top: 5px;\n  margin-bottom: 10px;\n}\n\n.result-table th {\n  border: 1px solid #000;\n  padding: 6px;\n  text-align: left;\n  font-weight: bold;\n  background-color: #f0f0f0;\n}\n\n.result-table td {\n  border: 1px solid #000;\n  padding: 6px;\n}\n\n.totals-row td {\n  border-top: 2px solid #000;\n  background-color: #f9f9f9;\n}\n\n/* Net pay summary */\n.summary-table td {\n  font-size: 11pt;\n}\n\n.net-pay-row td {\n  border-top: 2px solid #000;\n  font-size: 12pt;\n  background-color: #f0f0f0;\n}\n\n.in-words {\n  margin-top: 10px;\n  font-size: 10.5pt;\n  font-style: italic;\n}\n\n.ytd-note {\n  margin-top: 5px;\n  font-size: 10pt;\n}\n\n.text-right {\n  text-align: right;\n  margin-top: 30px;\n}\n\n.footer {\n  margin-top: 40px;\n  border-top: 1px solid #000;\n  padding-top: 8px;\n  font-size: 10pt;\n  text-align: center;\n}\n\n</style>",
